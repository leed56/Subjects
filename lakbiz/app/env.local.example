# Copy to .env.local (never commit .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — NEVER expose in browser or commit to git
# Required for super admin: create shops, reset passwords
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# When true, hide public signup — only admin-created shops can log in
# NEXT_PUBLIC_ADMIN_ONLY=true

# Optional: SMS reminders via Text.lk (server)
# SUPABASE_SERVICE_ROLE_KEY=...
# TEXTLK_API_TOKEN=...
# TEXTLK_SENDER_ID=...
# NEXT_PUBLIC_SMS_API_ENABLED=true
# CRON_SECRET=...
